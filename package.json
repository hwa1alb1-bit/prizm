{
  "name": "prizm",
  "version": "0.1.0-alpha.0",
  "private": true,
  "description": "PRIZM: lean PDF bank statement to Excel and CSV converter",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev -p 3030",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:kotlin-extractor": "node scripts/run-kotlin-extractor-tests.mjs",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:connectors:live": "tsx --conditions react-server scripts/smoke-live-connectors.ts",
    "benchmark:extraction": "tsx --conditions react-server scripts/benchmark-extraction.ts",
    "check:launch-gates": "tsx --conditions react-server scripts/check-launch-gates.ts",
    "verify:cloudflare-extractor-dry-run": "tsx scripts/verify-cloudflare-extractor-dry-run.ts",
    "verify:extraction": "pnpm exec vitest run tests/unit/cloudflare-extractor-worker.test.ts tests/unit/extraction-engine.test.ts tests/unit/extraction-benchmark-script.test.ts tests/unit/cloudflare-extractor-dry-run-script.test.ts && pnpm test:kotlin-extractor && pnpm benchmark:extraction && pnpm verify:cloudflare-extractor-dry-run",
    "verify:release": "tsx --conditions react-server scripts/verify-release.ts",
    "verify:service-readiness": "tsx --conditions react-server scripts/archive-service-readiness.ts",
    "verify": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "verify:full": "pnpm verify && pnpm test:e2e && pnpm test:connectors:live",
    "seed:stripe": "node --env-file=.env.local --import tsx scripts/seed-stripe.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/client-textract": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@sentry/nextjs": "^10.50.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@upstash/redis": "^1.37.0",
    "@vercel/oidc-aws-credentials-provider": "^3.1.0",
    "exceljs": "^4.4.0",
    "next": "16.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "server-only": "^0.0.1",
    "stripe": "^22.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/containers": "^0.3.3",
    "@playwright/test": "^1.59.1",
    "@sentry/cli": "^3.4.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "overrides": {
      "fast-uri": "3.1.2",
      "fast-xml-builder": "1.1.7",
      "postcss": "8.5.12"
    }
  }
}
