# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3030

# Launch gates (set to staging or production before running launch checks)
LAUNCH_GATE_TARGET=
LIVE_CONNECTOR_SMOKE=

# Extraction engine (Textract remains the default; enable legacy worker only outside production)
PRIZM_EXTRACTION_ENGINE=textract
KOTLIN_WORKER_URL=
KOTLIN_WORKER_API_KEY=

# Cloudflare R2/Kotlin launch path (requires staging proof before production)
DOCUMENT_STORAGE_PROVIDER=s3
DOCUMENT_EXTRACTION_PROVIDER=textract
R2_ACCOUNT_ID=
R2_UPLOAD_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
CLOUDFLARE_EXTRACTOR_URL=
CLOUDFLARE_EXTRACTOR_TOKEN=
CLOUDFLARE_EXTRACTOR_HEALTHCHECK_STORAGE_KEY=
CLOUDFLARE_EXTRACTION_STAGING_PROOF_ID=
CLOUDFLARE_EXTRACTION_STAGING_PROOF_AT=
CLOUDFLARE_EXTRACTION_STAGING_PROOF_SHA=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AWS (use OIDC role assumption from Vercel in prod, static keys here only for local dev)
AWS_REGION=us-east-1
AWS_ROLE_ARN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=prizm-uploads-staging
S3_KMS_KEY_ID=

# Stripe (test/sandbox mode keys for dev)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Sandbox price IDs created in account acct_1TRZG9KKeaydfVMo
STRIPE_PRICE_STARTER_MONTHLY=price_1TTAwOKKeaydfVMo0nF94pGo
STRIPE_PRICE_STARTER_ANNUAL=price_1TTAwPKKeaydfVMooDCvqzd3
STRIPE_PRICE_PRO_MONTHLY=price_1TTAwPKKeaydfVMohItR2XN4
STRIPE_PRICE_PRO_ANNUAL=price_1TTAwQKKeaydfVMoa48PLj1u
# Overage pricing requires a billing meter. Run pnpm seed:stripe to provision.
STRIPE_PRICE_OVERAGE_PAGE=price_1TTAwQKKeaydfVMoqlGhGNV4
STRIPE_METER_OVERAGE=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@prizmview.app

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Upstash Redis (rate limiting + idempotency)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Ops provider collector credentials
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=
AWS_SES_INBOUND_BUCKET=

# Cron auth (Vercel Cron header secret)
CRON_SECRET=
