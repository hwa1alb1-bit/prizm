# Copy to .env.local and fill in real values. Never commit .env.local.

# Public site
NEXT_PUBLIC_SITE_URL=http://localhost:3030

# Launch gates (set to staging or production before running launch checks)
LAUNCH_GATE_TARGET=
LIVE_CONNECTOR_SMOKE=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AWS (use OIDC role assumption from Vercel in prod, static keys here only for local dev)
AWS_REGION=us-east-1
AWS_ROLE_ARN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_UPLOAD_BUCKET=prizm-uploads-staging
S3_KMS_KEY_ID=

# Stripe (test/sandbox mode keys for dev)
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Sandbox price IDs created 2026-04-29 in account acct_1TRZFv44hvL1QSxT
STRIPE_PRICE_STARTER_MONTHLY=price_1TRcJnKKeaydfVMoOoyW2iAD
STRIPE_PRICE_STARTER_ANNUAL=price_1TRcJrKKeaydfVMooupLbq1k
STRIPE_PRICE_PRO_MONTHLY=price_1TRcJvKKeaydfVMozYaOPrPl
STRIPE_PRICE_PRO_ANNUAL=price_1TRcJyKKeaydfVMozTWrDzQo
# Overage pricing requires a billing meter. Run pnpm seed:stripe to provision.
STRIPE_PRICE_OVERAGE_PAGE=
STRIPE_METER_OVERAGE=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@prizmview.app

# Sentry
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Upstash Redis (rate limiting + idempotency)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Ops provider collector credentials
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=
AWS_SES_INBOUND_BUCKET=

# Cron auth (Vercel Cron header secret)
CRON_SECRET=
